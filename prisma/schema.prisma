// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Tenant
// ---------------------------------------------------------------------------

// Ciclo de vida operacional da Company — ver docs/adr/ADR-001, seção 1.1.
enum CompanyOperationalStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

// Estado de CONTROLE da empresa (quem detém a conta hoje) — independente de
// `CompanyOrigin` (como/por quem ela nasceu). Pré-cadastro é uma origem, não
// um estado de controle: uma empresa pré-cadastrada por consultoria nasce
// UNCLAIMED, não "PRE_REGISTERED". Ver docs/adr/ADR-001, seção 1.1.
enum CompanyControlStatus {
  UNCLAIMED
  CLAIM_PENDING
  CLAIMED
  DISPUTED
}

// Como a Company nasceu — nunca muda depois de criada. Ver docs/adr/ADR-001,
// seção 1.1.
enum CompanyOrigin {
  SELF_REGISTRATION
  SST_PROVIDER
  SUPER_ADMIN
  IMPORT
}

// Tipo do documento em `documentOriginal`/`documentNormalized` (preparação
// para suportar cadastro estrangeiro no futuro; nenhum dos dois campos é
// preenchido nesta migration).
enum CompanyDocumentType {
  CNPJ
  FOREIGN_REGISTRATION
}

// Estado de um vínculo User<->Company (M2A — ver docs/adr/ADR-001, seções
// 2.2 e 3). Nasce INVITED por padrão; o backfill legado (M2B,
// scripts/backfill-company-memberships.ts) cria diretamente como ACTIVE.
enum CompanyMembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REVOKED
}

// Sprint SST 1.4C — estado de UMA solicitação para assumir a administração
// de uma Company. Nunca confundir com CompanyMembership (a solicitação NÃO
// concede acesso) nem com SstProviderCompany (isso é vínculo de consultoria,
// não de dono empresarial). PENDING/UNDER_REVIEW são os únicos estados
// "ativos" (bloqueiam nova Company duplicada, aparecem na página de
// acompanhamento); os demais são terminais para aquele par (company,
// requester) — uma nova tentativa reabre a mesma linha (nunca cria outra,
// ver @@unique abaixo).
enum CompanyClaimRequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

// Como a solicitação nasceu — nunca muda depois de criada (mesmo espírito de
// CompanyOrigin). EXISTING_PRE_REGISTRATION = a Company já existia (UNCLAIMED,
// pré-cadastrada por uma consultoria SST); SELF_REGISTRATION = a Company foi
// criada nesta mesma tentativa de registro (CNPJ inexistente até então).
enum CompanyClaimRequestOrigin {
  SELF_REGISTRATION
  EXISTING_PRE_REGISTRATION
}

model Company {
  id        String   @id @default(cuid())
  name      String
  document  String?
  // Celular de contato da empresa, no padrão brasileiro (ex.: "(11)
  // 98765-4321") — preenchido opcionalmente no registro público
  // (app/register). Armazenado já formatado (mesma máscara exibida no
  // formulário); não há normalização/dígitos-puros porque o telefone não é
  // usado em busca/filtro em nenhum lugar do app.
  phone     String?
  // Painel completo da empresa (app/(app)/configuracoes/empresa) — mesmo
  // conjunto de campos já usado em `Supplier` (corporateName/tradeName/
  // email/phone/address/city/state/zipCode), reaproveitado aqui em vez de
  // inventar um formato de endereço novo. Todos opcionais: nenhum é
  // obrigatório para a empresa continuar operando.
  tradeName       String?
  email           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  // Nome do responsável pela empresa (ex.: representante legal) — aparece
  // nos termos de custódia junto com os outros dados da empresa.
  responsibleName String?
  // Logo em base64 (mesmo padrão de CustodyPhoto.dataUrl — sem storage
  // externo configurado no projeto). Exibida no cabeçalho do app, nos
  // termos de custódia e na página de QR Code.
  logoDataUrl     String?
  // Config da Evolution API (WhatsApp) desta empresa — usada para enviar o
  // termo de responsabilidade por WhatsApp na entrega (ver
  // lib/evolution-api.ts). Por empresa, não global: cada tenant conecta sua
  // própria instância/número. Todos opcionais porque o envio por WhatsApp é
  // um recurso opcional (a entrega funciona normalmente sem isso).
  whatsappApiUrl       String?
  whatsappApiKey       String?
  whatsappInstanceName String?
  active    Boolean  @default(true)

  // --- Ciclo de vida e proveniência (M1 — ver docs/adr/ADR-001) ---
  operationalStatus   CompanyOperationalStatus @default(ACTIVE)
  controlStatus       CompanyControlStatus     @default(CLAIMED)
  origin              CompanyOrigin            @default(SELF_REGISTRATION)

  // Quem criou a empresa quando ela nasce de um pré-cadastro de consultoria
  // (FUTURO). A empresa continua sendo a dona dos dados; isto é só
  // proveniência histórica. onDelete: Restrict — o prestador é sempre
  // desativado logicamente (SstProvider.active = false), nunca apagado
  // fisicamente; não há hoje nenhum fluxo de hard delete de SstProvider no
  // repositório (ver prisma/proposed/README.md), então a constraint nunca
  // bloqueia uma operação real.
  createdByProviderId String?
  createdByProvider   SstProvider? @relation("CompaniesCreatedByProvider", fields: [createdByProviderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  claimedAt            DateTime? // preenchido só quando a reivindicação (FUTURO) for concluída; NULL para todo registro existente (data histórica real desconhecida)

  // Normalização de documento (Sprint Comercial SST 1.4) — preenchidos em
  // todo caminho de criação de empresa (registro público, pré-cadastro SST,
  // seeds) e retroativamente para as empresas já existentes via
  // scripts/backfill-company-documents.ts. Continuam NULLABLE (não NOT
  // NULL): 1 empresa (possível dado real com CNPJ digitado incorretamente)
  // não pôde ser corrigida sem inventar um CNPJ — ver o script e o relatório
  // de entrega da sprint. `document` (acima) continua sincronizado
  // (representação mascarada) enquanto outro código ainda o lê.
  // `@@unique([documentType, documentNormalized])` abaixo é a última linha
  // de defesa contra duas empresas com o mesmo CNPJ.
  documentType        CompanyDocumentType?
  documentOriginal    String?
  documentNormalized  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories      AssetCategory[]
  manufacturers   Manufacturer[]
  suppliers       Supplier[]
  assetStatuses   AssetStatus[]
  assetConditions AssetCondition[]
  locationTypes   LocationType[]
  movementTypes   MovementType[]
  assets          Asset[]
  locations       Location[]
  assetUnits      AssetUnit[]
  custodies       AssetCustody[]
  assetMovements  AssetMovement[]
  stockBalances   StockBalance[]
  stockMovements  StockMovement[]
  users           User[]
  roles           Role[]
  userRoles       UserRole[]
  departments     Department[]
  positions       Position[]
  employees       Employee[]
  assetCertifications AssetCertification[]
  companyTrainings    CompanyTraining[]
  trainingClasses     TrainingClass[]
  trainingParticipants TrainingParticipant[]
  sstProviderLinks    SstProviderCompany[]
  custodyDocuments    CustodyDocument[]
  custodySignatures   CustodySignature[]
  custodyPhotos       CustodyPhoto[]
  custodySignatureRequests CustodySignatureRequest[]
  auditLogs                AuditLog[]
  memberships               CompanyMembership[]
  claimRequests             CompanyClaimRequest[]

  @@index([createdByProviderId])
  // Última linha de defesa contra duas empresas com o mesmo CNPJ (Sprint
  // Comercial SST 1.4, §8) — sempre a fonte final de verdade contra corrida
  // entre requisições concorrentes (o código de aplicação também confere
  // antes de criar, mas só esta constraint garante atomicidade real).
  // `documentType`/`documentNormalized` continuam NULLABLE nesta migration
  // (não NOT NULL): 1 empresa em produção/dev ("Alves Shopping da
  // construção LTDA", possível dado real com CNPJ digitado incorretamente)
  // ainda não tem os dois campos preenchidos e não deve receber um CNPJ
  // inventado — ver scripts/backfill-company-documents.ts. Índice único do
  // Postgres permite múltiplos NULLs, então isso não bloqueia a constraint
  // nem cria falso conflito entre registros ainda não migrados.
  @@unique([documentType, documentNormalized])
}

// ---------------------------------------------------------------------------
// Vínculo User<->Company (M2A — ver docs/adr/ADR-001, seções 2.2 e 3). Base
// para multi-tenant por usuário: um User poderá pertencer a mais de uma
// Company através de memberships independentes. Nesta sprint a tabela só é
// criada e populada via backfill 1:1 a partir de User.companyId — nenhuma
// rota lê/escreve nela ainda, e requireCompany() continua usando só
// User.companyId. Sem FK para UserRole (decisão do ADR-001, §3): o
// invariante Role.companyId == companyId da membership ativa é garantido em
// código (futuro resolver central), não por constraint de banco.
// ---------------------------------------------------------------------------

model CompanyMembership {
  id              String                  @id @default(cuid())
  userId          String
  companyId       String
  status          CompanyMembershipStatus @default(INVITED)

  invitedByUserId String?
  invitedAt       DateTime                @default(now())
  activatedAt     DateTime?
  suspendedAt     DateTime?
  revokedAt       DateTime?

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  // onDelete: Cascade — uma membership não existe sem o usuário titular.
  user            User     @relation("CompanyMembershipUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // onDelete: Restrict — nunca apagar fisicamente uma Company que ainda tem
  // membership vinculada (mesma lógica de createdByProviderId na M1).
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  // onDelete: SetNull — invitedByUserId é proveniência acessória ("quem
  // convidou"); excluir esse usuário preserva a membership do convidado.
  invitedByUser   User?    @relation("CompanyMembershipInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([userId, companyId])
  @@index([companyId, status])
  @@index([userId, status])
  @@index([invitedByUserId])
}

// ---------------------------------------------------------------------------
// Solicitação de reivindicação de Company (Sprint SST 1.4C — contenção da
// vulnerabilidade em que só conhecer um CNPJ válido já concedia
// CompanyMembership ACTIVE + papel ADMIN imediatamente, sem nenhuma
// comprovação de representação legal). Uma linha aqui é só a INTENÇÃO de
// assumir a administração de uma Company — nunca concede acesso por si só;
// CompanyMembership só é criada por `approveCompanyClaimRequest`
// (lib/company-claim-request.ts), nunca automaticamente.
//
// `@@unique([companyId, requesterUserId])` é proposital: uma nova tentativa
// do mesmo usuário para a mesma empresa sempre REABRE esta mesma linha
// (nunca cria uma segunda) — impede acúmulo infinito de solicitações PENDING
// duplicadas e preserva o histórico (createdAt original nunca muda,
// requestedAt é atualizado a cada reabertura). Uma pessoa DIFERENTE pode
// enviar sua própria solicitação (linha própria, `requesterUserId`
// diferente) — isso pode levar `Company.controlStatus` a DISPUTED quando
// há mais de um solicitante ativo (ver lib/company-claim-request.ts).
// ---------------------------------------------------------------------------

model CompanyClaimRequest {
  id              String                    @id @default(cuid())
  companyId       String
  requesterUserId String
  status          CompanyClaimRequestStatus @default(PENDING)
  origin          CompanyClaimRequestOrigin

  requestedAt      DateTime  @default(now())
  reviewedAt       DateTime?
  reviewedByUserId String?
  rejectionReason  String?
  // Reservado para expiração futura de solicitações esquecidas — nenhum job
  // preenche/consome este campo nesta sprint (fora de escopo, ver §21 do
  // spec: nenhuma automação de expiração ainda).
  expiresAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // onDelete: Restrict — nunca apagar fisicamente uma Company que ainda tem
  // solicitação vinculada (mesmo padrão de CompanyMembership.company acima).
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  // onDelete: Restrict — a solicitação é histórico de quem pediu; não pode
  // sobreviver sem o requerente identificado (diferente de "quem revisou",
  // que é só proveniência acessória, ver reviewedByUser abaixo).
  requester User @relation("CompanyClaimRequester", fields: [requesterUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  // onDelete: SetNull — excluir o revisor não pode apagar o histórico da
  // decisão em si (mesmo padrão de SstProviderCompany.companyReviewedByUser).
  reviewedByUser User? @relation("CompanyClaimReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([companyId, requesterUserId])
  @@index([companyId, status, requestedAt])
  @@index([requesterUserId, status])
  @@index([status, requestedAt])
}

// ---------------------------------------------------------------------------
// Autenticação (Better Auth) — nomes e campos seguem exatamente o schema
// que o adapter Prisma do Better Auth espera (ver docs/auth-rbac.md).
// IDs usam @default(cuid()) porque `advanced.database.generateId: false`
// está setado em lib/auth.ts, delegando a geração de id ao Prisma/Postgres.
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  // Sprint SST 1.4C.1 — nullable desde esta sprint: um usuário recém-
  // registrado não tem mais nenhuma Company "sua" até que uma
  // CompanyClaimRequest seja aprovada (lib/company-claim-request.ts). Só
  // `approveCompanyClaimRequest` preenche esta coluna, e só como preferência
  // (nunca autorização — CompanyMembership continua sendo a fonte real,
  // ver lib/company-context.ts). Nunca preenchido silenciosamente para um
  // usuário multiempresa que já tem uma preferência própria — ver o próprio
  // approveCompanyClaimRequest.
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id])
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions  Session[]
  accounts  Account[]
  userRoles UserRole[]
  // `SetNull` (não `Restrict`) — excluir um usuário não pode ficar
  // bloqueado por ele ter ações de auditoria registradas como ator; o log
  // continua legível pelo `actorName` congelado em cada linha.
  auditLogsAsActor AuditLog[] @relation("AuditLogActor")
  // `SetNull` — mesma lógica de auditLogsAsActor: excluir o usuário que
  // aprovou um vínculo não pode ficar bloqueado por isso.
  sstProviderCompanyApprovals SstProviderCompany[] @relation("SstProviderCompanyApprovedBy")
  // Revisões de vínculo pelo lado da empresa (aprovação comum ou decisão de
  // reivindicação) — ver SstProviderCompany.companyReviewedByUserId.
  sstProviderCompanyReviews   SstProviderCompany[] @relation("SstProviderCompanyReviewedBy")
  sstProviderUsers SstProviderUser[]
  companyMemberships          CompanyMembership[] @relation("CompanyMembershipUser")
  invitedCompanyMemberships   CompanyMembership[] @relation("CompanyMembershipInviter")
  companyClaimRequestsMade     CompanyClaimRequest[] @relation("CompanyClaimRequester")
  companyClaimRequestsReviewed CompanyClaimRequest[] @relation("CompanyClaimReviewer")

  @@index([companyId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ---------------------------------------------------------------------------
// RBAC — Role é parametrizável por empresa (mesma lógica de AssetStatus /
// AssetCondition / etc.); Permission é um catálogo global de capacidades do
// código. Um usuário pode ter mais de um Role dentro da mesma empresa.
// ---------------------------------------------------------------------------

model Role {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  // true para os 6 papéis padrão criados pelo seed; ajuda a diferenciar de
  // roles customizados que a empresa venha a criar no futuro.
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  userRoles   UserRole[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// Atribuição de um Role a um User dentro de uma Company específica.
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([companyId])
  @@index([userId])
}

// Trilha de auditoria de ações administrativas críticas (ex.: criação,
// bloqueio, redefinição de senha e exclusão de usuários — ver
// app/(app)/configuracoes/usuarios). `targetId` é só uma string indexada,
// sem relação: o alvo de uma ação (ex.: o usuário sendo excluído) pode não
// existir mais no banco no momento em que o log é consultado depois.
// Distingue quem agiu: usuário do Portal Empresa (padrão, todo histórico
// anterior a esta coluna vira COMPANY_USER via @default) ou usuário do
// Portal Consultoria SST agindo em nome de um provider (ver
// docs/portal-consultoria.md). Não substitui actorUserId/actorName — um
// SstProviderUser também é um User real, então essas colunas continuam
// preenchidas normalmente; actorType/providerId só adicionam contexto de
// qual portal originou a ação.
enum AuditActorType {
  COMPANY_USER
  SST_PROVIDER_USER
}

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  actorUserId String?
  actor       User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorName   String
  actorType   AuditActorType @default(COMPANY_USER)
  providerId  String?
  provider    SstProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  action      String
  targetType  String
  targetId    String?
  targetLabel String?
  metadata    Json?
  // Propagados por proxy.ts em toda requisição (ver lib/logger.ts) — cruza
  // esta linha de auditoria com a linha correspondente do log estruturado.
  requestId     String?
  correlationId String?
  createdAt     DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([targetType, targetId])
  @@index([requestId])
  @@index([providerId])
}

// ---------------------------------------------------------------------------
// Cadastros de apoio
// ---------------------------------------------------------------------------

model AssetCategory {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  name        String
  description String?
  color       String?
  icon        String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  assets Asset[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Manufacturer {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  document  String?
  website   String?
  email     String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  assets Asset[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Supplier {
  id                    String   @id @default(cuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id])
  corporateName         String
  tradeName             String?
  document              String?
  stateRegistration     String?
  municipalRegistration String?
  email                 String?
  phone                 String?
  contactName           String?
  address               String?
  city                  String?
  state                 String?
  zipCode               String?
  notes                 String?
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  assets Asset[]

  @@unique([companyId, corporateName])
  @@index([companyId])
}

// Parametrizável por empresa (não usar Enum fixa, conforme regra de negócio).
model AssetStatus {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  color       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assetUnits AssetUnit[]
  assets     Asset[]

  @@unique([companyId, name])
  @@index([companyId])
}

// Parametrizável por empresa (não usar Enum fixa, conforme regra de negócio).
model AssetCondition {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assetUnits AssetUnit[]
  assets     Asset[]

  @@unique([companyId, name])
  @@index([companyId])
}

// Parametrizável por empresa; substitui a lista fixa sugerida
// (WAREHOUSE, EMPLOYEE, BRANCH, VEHICLE, SUPPLIER, CUSTOMER,
// CONSTRUCTION_SITE, SERVICE_CENTER, SCRAP).
model LocationType {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations Location[]

  @@index([companyId])
}

// Parametrizável por empresa; compartilhado entre AssetMovement e
// StockMovement (ENTRY, EXIT, ASSIGNMENT, RETURN, TRANSFER, RESERVATION,
// INVENTORY, ADJUSTMENT, LOSS, THEFT, DISPOSAL, MAINTENANCE_OUT,
// MAINTENANCE_IN, CALIBRATION, INSPECTION são os tipos oficiais sugeridos).
model MovementType {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assetMovements AssetMovement[]
  stockMovements StockMovement[]

  @@index([companyId])
}

enum TrackingMode {
  INDIVIDUAL
  CONSUMABLE
}

// ---------------------------------------------------------------------------
// Cadastro mestre
// ---------------------------------------------------------------------------

model Asset {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])
  assetCode        String
  name             String
  description      String?
  categoryId       String
  category         AssetCategory @relation(fields: [categoryId], references: [id])
  manufacturerId   String?
  manufacturer     Manufacturer? @relation(fields: [manufacturerId], references: [id])
  supplierId       String?
  supplier         Supplier? @relation(fields: [supplierId], references: [id])
  statusId         String
  status           AssetStatus @relation(fields: [statusId], references: [id])
  conditionId      String
  condition        AssetCondition @relation(fields: [conditionId], references: [id])
  trackingMode     TrackingMode
  barcode          String?
  defaultUnit      String?
  photo            String?
  minimumStock     Decimal?  @db.Decimal(14, 3)
  maximumStock     Decimal?  @db.Decimal(14, 3)
  reorderPoint     Decimal?  @db.Decimal(14, 3)
  purchasePrice    Decimal?  @db.Decimal(14, 2)
  replacementCost  Decimal?  @db.Decimal(14, 2)
  expectedLifetime Int?
  warrantyMonths   Int?
  active           Boolean   @default(true)
  // Identificador público e opaco usado por /q/[token] e GET /api/qr/[token]
  // para rastreabilidade via QR Code — nunca o `id` (cuid) interno. Nulo até
  // alguém gerar o QR pela primeira vez (ver lib/qr-code.ts); a partir daí é
  // estável (reimprimir a mesma etiqueta física continua funcionando).
  qrCodeToken      String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  assetUnits     AssetUnit[]
  assetMovements AssetMovement[]
  stockBalances  StockBalance[]
  stockMovements StockMovement[]
  certifications AssetCertification[]
  custodies      AssetCustody[]

  @@unique([companyId, assetCode])
  @@index([companyId])
  @@index([categoryId])
  @@index([manufacturerId])
  @@index([supplierId])
  @@index([statusId])
  @@index([conditionId])
  @@index([companyId, active])
  @@index([companyId, trackingMode])
}

// ---------------------------------------------------------------------------
// Certificações de ativos (CA, INMETRO, ANATEL, ISO, OUTROS).
//
// `certificationType` e `status` são enum (não tabela parametrizável por
// empresa como AssetStatus/AssetCondition) porque representam classificações
// regulatórias externas — quem evolui essa lista é a plataforma via
// migration, não cada empresa. Um Asset pode ter zero, uma ou várias
// certificações (histórico de CA antigo/vencido + CA vigente, por exemplo).
//
// Campos específicos de cada tipo (ex.: fabricante homologado, tipo de
// proteção e norma aplicável, no caso de CA) ficam em `metadata` (JSON) em
// vez de colunas dedicadas — mantém a tabela genérica para os próximos
// tipos, sem migration a cada novo tipo de certificação. Ver
// docs/certifications.md para o formato esperado de `metadata` por tipo e
// para a arquitetura de integração externa (CertificationProvider).
// ---------------------------------------------------------------------------

enum CertificationType {
  CA
  INMETRO
  ANATEL
  ISO
  OUTROS
}

enum CertificationStatus {
  VALID
  EXPIRED
  SUSPENDED
  CANCELLED
  PENDING
}

model AssetCertification {
  id                  String              @id @default(cuid())
  companyId           String
  company             Company             @relation(fields: [companyId], references: [id])
  assetId             String
  asset               Asset               @relation(fields: [assetId], references: [id])
  certificationType   CertificationType
  certificationNumber String
  issueDate           DateTime?
  expirationDate      DateTime?
  status              CertificationStatus @default(VALID)
  issuer              String?
  documentUrl         String?
  // Id do registro no sistema externo de origem (ex.: API do provedor de
  // CA), para permitir sincronização/atualização futura sem duplicar.
  externalId          String?
  // Último momento em que os dados foram confirmados/atualizados por um
  // CertificationProvider externo. Nulo quando o registro foi criado/editado
  // manualmente e nunca sincronizado.
  lastSyncAt          DateTime?
  // Dados específicos do tipo de certificação que não fazem sentido como
  // coluna genérica (ex., para CA: fabricante homologado, descrição
  // oficial, tipo de proteção, norma aplicável).
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([companyId, certificationType, certificationNumber])
  @@index([companyId])
  @@index([assetId])
  @@index([expirationDate])
  @@index([companyId, certificationType, status, expirationDate])
}

// ---------------------------------------------------------------------------
// Localização (qualquer lugar onde um ativo pode permanecer)
// ---------------------------------------------------------------------------

model Location {
  id             String       @id @default(cuid())
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id])
  locationTypeId String
  locationType   LocationType @relation(fields: [locationTypeId], references: [id])
  // Aponta para o id da entidade referenciada (Employee, Vehicle, Branch,
  // Supplier, Customer, etc.) conforme o locationType. Sem FK de banco
  // porque o alvo varia por tipo — invariante garantido pela aplicação.
  referenceId    String?
  name           String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  currentAssetUnits          AssetUnit[]     @relation("AssetUnitCurrentLocation")
  custodies                  AssetCustody[]
  stockBalances              StockBalance[]
  movementsOrigin            AssetMovement[] @relation("AssetMovementOrigin")
  movementsDestination       AssetMovement[] @relation("AssetMovementDestination")
  stockMovementsOrigin       StockMovement[] @relation("StockMovementOrigin")
  stockMovementsDestination  StockMovement[] @relation("StockMovementDestination")

  @@index([companyId])
  @@index([locationTypeId])
  @@index([companyId, active])
}

// ---------------------------------------------------------------------------
// Unidade física individual (trackingMode = INDIVIDUAL)
// ---------------------------------------------------------------------------

model AssetUnit {
  id                 String         @id @default(cuid())
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id])
  assetId            String
  asset              Asset          @relation(fields: [assetId], references: [id])
  patrimonyNumber    String?
  serialNumber       String?
  qrCode             String?
  barcode            String?
  manufactureDate    DateTime?
  purchaseDate       DateTime?
  purchaseValue      Decimal?       @db.Decimal(14, 2)
  currentValue       Decimal?       @db.Decimal(14, 2)
  warrantyExpiration DateTime?
  statusId           String
  status             AssetStatus    @relation(fields: [statusId], references: [id])
  conditionId        String
  condition          AssetCondition @relation(fields: [conditionId], references: [id])
  currentLocationId  String?
  currentLocation    Location?      @relation("AssetUnitCurrentLocation", fields: [currentLocationId], references: [id])
  // Ponteiro para a custódia ativa (1-1). O histórico completo fica em
  // `custodies`, nunca é sobrescrito.
  currentCustodyId   String?        @unique
  currentCustody     AssetCustody?  @relation("AssetUnitCurrentCustody", fields: [currentCustodyId], references: [id])
  notes              String?
  active             Boolean        @default(true)
  // Distinto do `qrCode` acima (campo livre do cadastro original, preenchido
  // manualmente): `qrCodeToken` é o identificador público opaco gerado pela
  // aplicação para /q/[token] — ver comentário equivalente em Asset.
  qrCodeToken        String?        @unique
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  movements AssetMovement[]
  custodies AssetCustody[]  @relation("AssetUnitCustodyHistory")

  @@unique([companyId, patrimonyNumber])
  @@unique([companyId, serialNumber])
  @@index([companyId])
  @@index([assetId])
  @@index([currentLocationId])
  @@index([statusId])
  @@index([conditionId])
}

enum CustodyStatus {
  ACTIVE
  RETURNED
}

// ---------------------------------------------------------------------------
// Custódia (responsabilidade de um colaborador sobre um ativo — patrimoniado
// ou consumível). `assetId` é sempre obrigatório (inclusive quando há
// AssetUnit, é denormalizado dali) porque custódias de consumível não têm
// unidade nenhuma; `assetUnitId` só é preenchido para trackingMode
// INDIVIDUAL. "Atrasado" não é um status persistido: é derivado em
// lib/custodies.ts (status ACTIVE + expectedReturnAt no passado), mesmo
// critério usado para o badge de CA em lib/certifications/badge.ts.
// ---------------------------------------------------------------------------

model AssetCustody {
  id               String        @id @default(cuid())
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id])
  employeeId       String
  employee         Employee      @relation(fields: [employeeId], references: [id])
  assetId          String
  asset            Asset         @relation(fields: [assetId], references: [id])
  assetUnitId      String?
  assetUnit        AssetUnit?    @relation("AssetUnitCustodyHistory", fields: [assetUnitId], references: [id])
  holderLocationId String
  holderLocation   Location      @relation(fields: [holderLocationId], references: [id])
  quantity         Decimal       @db.Decimal(14, 3)
  status           CustodyStatus @default(ACTIVE)
  deliveredAt      DateTime
  expectedReturnAt DateTime?
  returnedAt       DateTime?
  reason           String?
  notes            String?
  createdBy        String?
  // Identificador público opaco para /q/[token] (ver comentário em Asset) —
  // permite que o QR fixado num item entregue leve direto ao status da
  // custódia e do termo/assinatura (requisito de rastreabilidade).
  qrCodeToken      String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  currentForAssetUnit AssetUnit?      @relation("AssetUnitCurrentCustody")
  movements           AssetMovement[]
  documents           CustodyDocument[]
  signatures          CustodySignature[]
  photos              CustodyPhoto[]
  signatureRequests   CustodySignatureRequest[]

  @@index([companyId])
  @@index([assetUnitId])
  @@index([employeeId])
  @@index([assetId])
  @@index([status])
  @@index([companyId, status, expectedReturnAt])
  @@index([companyId, deliveredAt])
}

// ---------------------------------------------------------------------------
// Documentos e assinatura digital de custódia — evidência formal da
// entrega/devolução. `type` é enum (não tabela parametrizável): o conteúdo e
// o momento em que cada termo pode ser gerado são regras da própria
// plataforma (DELIVERY_TERM a qualquer momento; RETURN_TERM só após a
// custódia ser devolvida — ver lib/custodies/index.ts), não uma customização
// por empresa. `pdfUrl` fica preparado para uma etapa futura de geração de
// PDF (não implementada agora); o termo hoje só existe como HTML.
// ---------------------------------------------------------------------------

enum CustodyDocumentType {
  DELIVERY_TERM
  RETURN_TERM
}

model CustodyDocument {
  id          String              @id @default(cuid())
  companyId   String
  company     Company             @relation(fields: [companyId], references: [id])
  custodyId   String
  custody     AssetCustody        @relation(fields: [custodyId], references: [id])
  type        CustodyDocumentType
  contentHtml String
  pdfUrl      String?
  generatedAt DateTime
  createdAt   DateTime            @default(now())

  signatures        CustodySignature[]
  signatureRequests CustodySignatureRequest[]

  @@index([companyId])
  @@index([custodyId])
}

enum SignatureRequestStatus {
  PENDING
  SENT
  SIGNED
}

// Solicitação de assinatura remota do termo de entrega via WhatsApp (ver
// lib/evolution-api.ts e app/assinar/[token]) — alternativa à assinatura
// presencial (CustodySignature capturada direto no formulário de entrega).
// `token` é opaco e de uso único, gerado com o mesmo `generateQrToken()` do
// fluxo de QR Code, mas enviado privadamente ao WhatsApp de uma pessoa
// específica (não impresso/exposto como o QR) — por isso a rota pública
// pode expor o `contentHtml` do termo sem restrição adicional.
model CustodySignatureRequest {
  id         String                 @id @default(cuid())
  companyId  String
  company    Company                @relation(fields: [companyId], references: [id])
  custodyId  String
  custody    AssetCustody           @relation(fields: [custodyId], references: [id])
  documentId String
  document   CustodyDocument        @relation(fields: [documentId], references: [id])
  token      String                 @unique
  // Nulo quando a solicitação é presencial (QR Code lido na hora, sem envio
  // por WhatsApp) — ver app/(app)/custodies/deliver-form.tsx.
  phone      String?
  status     SignatureRequestStatus @default(PENDING)
  sentAt     DateTime?
  signedAt   DateTime?
  createdAt  DateTime               @default(now())

  @@index([companyId])
  @@index([custodyId])
}

// Uma assinatura sempre referencia o CustodyDocument que foi assinado;
// `custodyId` é denormalizado do documento para permitir consultar todas as
// assinaturas de uma custódia sem precisar passar pela tabela de documentos.
// `signatureImageUrl`/`signatureData` são ambos opcionais no schema, mas a
// aplicação exige pelo menos um dos dois (ver
// lib/validations/custody-document.ts) — `signatureData` é o normal hoje
// (data URL base64 capturado do canvas de assinatura), `signatureImageUrl`
// fica preparado para quando houver upload de uma imagem já pronta.
model CustodySignature {
  id                String          @id @default(cuid())
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  custodyId         String
  custody           AssetCustody    @relation(fields: [custodyId], references: [id])
  documentId        String
  document          CustodyDocument @relation(fields: [documentId], references: [id])
  signerName        String
  signerDocument    String
  signatureImageUrl String?
  signatureData     String?
  signedAt          DateTime
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime        @default(now())

  @@index([companyId])
  @@index([custodyId])
  @@index([documentId])
}

enum CustodyPhotoKind {
  DELIVERY
  RETURN
}

// Fotos do item no momento da entrega e/ou devolução (até 5 por evento,
// limite aplicado na validação — ver lib/validations/custody.ts). Mesmo
// padrão de CustodySignature.signatureData: guarda a imagem como data URL
// base64 direto no banco (`dataUrl`), sem depender de storage externo —
// o client já comprime/redimensiona antes de enviar (ver
// components/custody/photo-picker.tsx) para manter cada imagem pequena.
model CustodyPhoto {
  id        String           @id @default(cuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  custodyId String
  custody   AssetCustody     @relation(fields: [custodyId], references: [id])
  kind      CustodyPhotoKind
  dataUrl   String
  createdAt DateTime         @default(now())

  @@index([companyId])
  @@index([custodyId])
}

// ---------------------------------------------------------------------------
// Movimentação de AssetUnit (trackingMode = INDIVIDUAL). Imutável: nunca
// editar, nunca excluir.
// ---------------------------------------------------------------------------

model AssetMovement {
  id                    String        @id @default(cuid())
  companyId             String
  company               Company       @relation(fields: [companyId], references: [id])
  assetId               String
  asset                 Asset         @relation(fields: [assetId], references: [id])
  assetUnitId           String?
  assetUnit             AssetUnit?    @relation(fields: [assetUnitId], references: [id])
  movementTypeId        String
  movementType          MovementType  @relation(fields: [movementTypeId], references: [id])
  quantity              Decimal       @db.Decimal(14, 3)
  originLocationId      String?
  originLocation        Location?     @relation("AssetMovementOrigin", fields: [originLocationId], references: [id])
  destinationLocationId String?
  destinationLocation   Location?     @relation("AssetMovementDestination", fields: [destinationLocationId], references: [id])
  custodyId             String?
  custody               AssetCustody? @relation(fields: [custodyId], references: [id])
  executedBy            String?
  executedAt             DateTime
  referenceType         String?
  referenceId           String?
  observations           String?
  createdAt              DateTime     @default(now())

  @@index([companyId])
  @@index([assetId])
  @@index([assetUnitId])
}

// ---------------------------------------------------------------------------
// Estoque de consumíveis (trackingMode = CONSUMABLE). StockBalance é apenas
// cache de leitura — nunca editar manualmente, sempre recalcular a partir de
// StockMovement.
// ---------------------------------------------------------------------------

model StockBalance {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  quantity   Decimal  @db.Decimal(14, 3)
  updatedAt  DateTime @updatedAt

  @@unique([assetId, locationId])
  @@index([companyId])
}

model StockMovement {
  id                    String       @id @default(cuid())
  companyId             String
  company               Company      @relation(fields: [companyId], references: [id])
  assetId               String
  asset                 Asset        @relation(fields: [assetId], references: [id])
  movementTypeId        String
  movementType          MovementType @relation(fields: [movementTypeId], references: [id])
  quantity               Decimal     @db.Decimal(14, 3)
  originLocationId      String?
  originLocation        Location?    @relation("StockMovementOrigin", fields: [originLocationId], references: [id])
  destinationLocationId String?
  destinationLocation   Location?    @relation("StockMovementDestination", fields: [destinationLocationId], references: [id])
  executedBy            String?
  executedAt             DateTime
  observations           String?
  createdAt               DateTime   @default(now())

  @@index([companyId])
  @@index([assetId])
}

// ---------------------------------------------------------------------------
// Colaboradores — cadastros de apoio (Department, Position) parametrizáveis
// por empresa, seguindo o mesmo padrão de AssetCategory/Manufacturer.
// ---------------------------------------------------------------------------

model Department {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Position {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

model Employee {
  id           String         @id @default(cuid())
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id])
  name         String
  document     String
  email        String?
  phone        String?
  registration String?
  departmentId String?
  department   Department?    @relation(fields: [departmentId], references: [id])
  positionId   String?
  position     Position?      @relation(fields: [positionId], references: [id])
  // "Excluir" na UI é soft delete: marca INACTIVE, nunca remove a linha —
  // preserva histórico caso movimentações/custódias venham a referenciar o
  // colaborador no futuro.
  status       EmployeeStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  custodies AssetCustody[]
  trainingParticipants TrainingParticipant[]

  @@unique([companyId, document])
  @@index([companyId])
  @@index([departmentId])
  @@index([positionId])
}

// ---------------------------------------------------------------------------
// Treinamentos — Sprint 0 (fundação do catálogo, ver docs/trainings-domain.md).
// Dois níveis: TrainingTemplate é o catálogo global mantido pela plataforma
// (não pertence a empresa nenhuma); CompanyTraining é o que a empresa
// realmente usa, sempre companyId obrigatório. Criar um CompanyTraining a
// partir de um TrainingTemplate copia os campos uma única vez — depois disso
// os dois são totalmente independentes (editar um nunca altera o outro).
// TrainingType/InstructorType são enums (classificação fixa da plataforma),
// não tabelas parametrizáveis por empresa como AssetStatus/AssetCondition —
// mesma categoria de CertificationType/CertificationStatus em
// AssetCertification.
// ---------------------------------------------------------------------------

enum TrainingType {
  LEGAL
  CORPORATE
}

enum InstructorType {
  INTERNAL
  EXTERNAL
  BOTH
}

// Catálogo global de modelos de treinamento (Integração, NR-01, NR-05, etc.).
// Somente leitura via API nesta sprint — sem endpoints de create/update/
// delete; a manutenção do catálogo inicial é via prisma/seed.ts.
model TrainingTemplate {
  id                     String         @id @default(cuid())
  title                  String
  code                   String         @unique
  description            String?
  category               String
  trainingType           TrainingType
  nrReference            String?
  defaultValidityMonths  Int?
  defaultWorkloadHours   Int?
  requiresCertificate    Boolean        @default(true)
  requiresAttendanceList Boolean        @default(true)
  requiresSignature      Boolean        @default(false)
  requiresExam           Boolean        @default(false)
  minimumPassingGrade    Int?
  defaultInstructorType  InstructorType @default(BOTH)
  // Suporta versionamento futuro do catálogo (ex.: nova versão de uma NR) sem
  // afetar CompanyTraining já criados a partir da versão anterior —
  // CompanyTraining copia os campos no momento da criação e nunca mais lê o
  // template de novo, então um bump aqui não retroage.
  version                Int            @default(1)
  active                 Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  companyTrainings CompanyTraining[]

  @@index([category])
  @@index([trainingType])
  @@index([active])
}

// Treinamento configurado por uma empresa — o que de fato é usado/agendado/
// vinculado a colaboradores nas sprints futuras (turmas, participantes,
// certificados). Pode nascer de um TrainingTemplate (cópia pontual) ou ser
// 100% customizado (trainingTemplateId nulo). "Excluir" na UI é soft delete
// (active: false) — nunca remove a linha.
model CompanyTraining {
  id                     String            @id @default(cuid())
  companyId              String
  company                Company           @relation(fields: [companyId], references: [id])
  trainingTemplateId     String?
  trainingTemplate       TrainingTemplate? @relation(fields: [trainingTemplateId], references: [id])
  title                  String
  description            String?
  category               String?
  trainingType           TrainingType
  nrReference            String?
  validityMonths         Int?
  workloadHours          Int?
  requiresCertificate    Boolean           @default(true)
  requiresAttendanceList Boolean           @default(true)
  requiresSignature      Boolean           @default(false)
  requiresExam           Boolean           @default(false)
  minimumPassingGrade    Int?
  instructorType         InstructorType    @default(BOTH)
  mandatory              Boolean           @default(false)
  // Quem gerencia operacionalmente este treinamento — a empresa continua
  // sendo a dona dos dados em ambos os casos (companyId nunca muda); isso só
  // marca quem opera no dia a dia. `@default(INTERNAL)` cobre todo registro
  // já existente sem precisar de backfill manual. Ver docs/sst-providers.md.
  managementMode         TrainingManagementMode @default(INTERNAL)
  managedByProviderId    String?
  managedByProvider      SstProvider?      @relation(fields: [managedByProviderId], references: [id])
  // Reservado para histórico futuro de revisões do próprio CompanyTraining —
  // contador independente da version do TrainingTemplate de origem (não
  // incrementado em lugar nenhum ainda nesta sprint).
  version                Int               @default(1)
  active                 Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  trainingClasses TrainingClass[]

  @@index([companyId])
  @@index([trainingTemplateId])
  @@index([companyId, active])
  @@index([companyId, trainingType])
  // Consulta natural do futuro Portal Consultoria ("todos os treinamentos
  // que este prestador gerencia, em todas as empresas") — ver
  // docs/training-architecture.md.
  @@index([managedByProviderId])
}

// ---------------------------------------------------------------------------
// Turmas — Sprint 1 (ver docs/trainings-domain.md). Uma turma agenda um
// CompanyTraining em uma data/local/instrutor concretos. Nunca é apagada —
// "cancelar" é só status: CANCELLED (sem endpoint DELETE, sem campo
// `active`/soft-delete como em CompanyTraining).
// ---------------------------------------------------------------------------

enum TrainingClassStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model TrainingClass {
  id                  String              @id @default(cuid())
  companyId           String
  company             Company             @relation(fields: [companyId], references: [id])
  companyTrainingId   String
  companyTraining     CompanyTraining     @relation(fields: [companyTrainingId], references: [id])
  title               String
  status              TrainingClassStatus @default(SCHEDULED)
  startsAt            DateTime
  endsAt              DateTime?
  // Texto livre — não referencia o model `Location` (rastreamento físico de
  // ativos, domínio diferente): aqui é só "onde a turma acontece".
  location            String?
  internalInstructor  String?
  externalInstructor  String?
  maximumParticipants Int?
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  participants TrainingParticipant[]

  @@index([companyId])
  @@index([companyTrainingId])
  @@index([companyId, status])
  @@index([companyId, startsAt])
}

// ---------------------------------------------------------------------------
// Participantes — Sprint 2 (ver docs/trainings-domain.md). Sempre um
// Employee já cadastrado na empresa — nunca um convidado externo; não existe
// (e não deve existir) uma tabela de "pessoa externa" para isso, mesmo
// pensando no futuro Portal SST (a consultoria opera sobre colaboradores já
// cadastrados, não cria pessoas soltas).
// ---------------------------------------------------------------------------

enum TrainingAttendanceStatus {
  ENROLLED
  PRESENT
  ABSENT
}

enum TrainingResultStatus {
  PENDING
  APPROVED
  FAILED
}

model TrainingParticipant {
  id               String                    @id @default(cuid())
  companyId        String
  company          Company                   @relation(fields: [companyId], references: [id])
  trainingClassId  String
  trainingClass    TrainingClass             @relation(fields: [trainingClassId], references: [id])
  employeeId       String
  employee         Employee                  @relation(fields: [employeeId], references: [id])
  attendanceStatus TrainingAttendanceStatus  @default(ENROLLED)
  resultStatus     TrainingResultStatus      @default(PENDING)
  enrolledAt       DateTime                  @default(now())
  // Setado tanto em APPROVED quanto em FAILED (quando a avaliação
  // termina) — só `expiresAt` é exclusivo de APPROVED. Ver
  // docs/trainings-domain.md.
  completedAt      DateTime?
  expiresAt        DateTime?
  notes            String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@unique([companyId, trainingClassId, employeeId])
  @@index([companyId])
  @@index([trainingClassId])
  @@index([employeeId])
  // Composto (não `expiresAt` isolado) porque toda leitura de vencimento é
  // sempre por empresa — mesmo padrão de alerta já usado no resto do
  // sistema (nunca uma varredura global). A futura sprint de alertas filtra
  // exatamente por esses dois campos juntos. Ver docs/training-architecture.md.
  @@index([companyId, expiresAt])
}

// ---------------------------------------------------------------------------
// Preparação arquitetural para o futuro Portal Consultoria (ver
// docs/sst-providers.md). Não implementa o portal, login de consultoria nem
// nenhuma tela além do lado da empresa — só a base para marcar que um
// CompanyTraining é gerenciado por uma consultoria SST externa em vez da
// própria empresa. A empresa continua sendo a dona dos dados em qualquer
// caso; a consultoria só recebe um nível de acesso operacional.
// ---------------------------------------------------------------------------

enum TrainingManagementMode {
  INTERNAL
  EXTERNAL_PROVIDER
}

// Catálogo global de prestadores SST — SEM companyId, de propósito: um
// prestador pode futuramente atender mais de uma empresa (mesmo raciocínio
// do futuro Portal Consultoria). O isolamento por empresa não vem de um
// companyId nesta tabela — vem inteiramente do vínculo SstProviderCompany.
// Nenhuma rota deve listar/expor SstProvider fora desse vínculo.
model SstProvider {
  id        String   @id @default(cuid())
  name      String
  document  String?
  email     String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyLinks     SstProviderCompany[]
  createdCompanies Company[] @relation("CompaniesCreatedByProvider")
  companyTrainings CompanyTraining[]
  providerUsers    SstProviderUser[]
  auditLogs        AuditLog[]
}

enum SstProviderCompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
  // Sprint Comercial SST 1.4, §15 — distinto de REVOKED (que só existe após
  // ter sido ACTIVE) e de SUSPENDED (pausa reversível de um vínculo já
  // autorizado): REJECTED é o estado final de uma solicitação PENDING que a
  // empresa recusou sem nunca ter autorizado. Nunca reutilizar REVOKED para
  // isso — conflaria "já teve acesso e foi revogado" com "nunca teve acesso".
  REJECTED
}

enum SstProviderCompanyAccessLevel {
  VIEW
  OPERATION
  ADMINISTRATION
}

// Distingue COMO um vínculo passou a existir/ficar ACTIVE — não confundir
// com `status` (o estado atual). Sprint Comercial SST 1.4 (extensão):
// PROVIDER_PRE_REGISTRATION é sempre provisório (a consultoria criou o
// primeiro pré-cadastro da empresa, `Company.controlStatus: UNCLAIMED`) —
// nunca propriedade, só acesso operacional aos módulos SST enquanto a
// empresa não reivindica o cadastro. COMPANY_APPROVAL é a aprovação real,
// feita por um usuário autenticado da própria empresa (via Portal Empresa
// ou pela decisão de reivindicação). SUPER_ADMIN é preparação para um
// futuro painel administrativo — não implementado nesta sprint.
enum SstProviderAuthorizationBasis {
  COMPANY_APPROVAL
  PROVIDER_PRE_REGISTRATION
  SUPER_ADMIN
}

// O vínculo em si — é aqui que mora o isolamento multi-tenant real: toda
// query do lado da empresa filtra por companyId nesta tabela, nunca em
// SstProvider direto. Só um vínculo ACTIVE com accessLevel OPERATION ou
// ADMINISTRATION permite que o prestador gerencie um CompanyTraining (VIEW
// nunca gerencia) — ver assertManagementModeValid em lib/trainings.ts.
model SstProviderCompany {
  id               String                         @id @default(cuid())
  providerId       String
  provider         SstProvider                    @relation(fields: [providerId], references: [id])
  companyId        String
  company          Company                        @relation(fields: [companyId], references: [id])
  status           SstProviderCompanyStatus       @default(PENDING)
  accessLevel      SstProviderCompanyAccessLevel
  startsAt         DateTime                       @default(now())
  endsAt           DateTime?
  approvedByUserId String?
  approvedByUser   User?                          @relation("SstProviderCompanyApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  revokedAt        DateTime?
  // Origem da autorização (Sprint Comercial SST 1.4, extensão — nunca
  // confundir com `status`) e o registro de quando/quem, do lado da
  // empresa, revisou este vínculo — preenchido tanto pela aprovação comum
  // (Portal Empresa) quanto pela decisão de reivindicação ("continuar
  // autorizando"/"bloquear"). Fica NULL enquanto o vínculo nunca foi
  // revisado por um humano da empresa (ex.: ainda PENDING, ou ACTIVE só por
  // PROVIDER_PRE_REGISTRATION).
  authorizationBasis      SstProviderAuthorizationBasis @default(COMPANY_APPROVAL)
  companyReviewedAt       DateTime?
  companyReviewedByUserId String?
  companyReviewedByUser   User?                         @relation("SstProviderCompanyReviewedBy", fields: [companyReviewedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  @@unique([providerId, companyId])
  @@index([companyId])
  @@index([providerId])
}

enum SstProviderUserRole {
  OWNER
  TECHNICIAN
  VIEWER
}

// Dá acesso ao Portal Consultoria (rotas /sst e /api/sst) — vincula um User
// (a mesma identidade do Portal Empresa) a um SstProvider. Um User pode ter
// um vínculo de empresa (User.companyId) E um vínculo de consultoria ao
// mesmo tempo, de forma totalmente independente: o Portal Consultoria
// NUNCA lê User.companyId como tenant, só este vínculo. Não é
// globalmente único em userId (só em [providerId, userId]) para permitir,
// no futuro, um mesmo usuário atuar em mais de uma consultoria.
model SstProviderUser {
  id         String              @id @default(cuid())
  providerId String
  provider   SstProvider         @relation(fields: [providerId], references: [id])
  userId     String
  user       User                @relation(fields: [userId], references: [id])
  role       SstProviderUserRole
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([providerId, userId])
  @@index([providerId])
  @@index([userId])
}
