// (1) NOVOS ENUMS — adicionar antes de `model Company`.

enum CompanyOperationalStatus {
  ACTIVE     // operando normalmente (default de toda empresa existente)
  SUSPENDED  // acesso temporariamente bloqueado, dado preservado
  CLOSED     // encerrada (contrato terminado) — dado preservado, acesso negado
}

// Estado de CONTROLE da empresa (quem detém a conta) — distinto de `origin`
// (como/por quem ela nasceu). Pré-cadastro é uma ORIGEM (ver CompanyOrigin),
// não um estado de controle: uma empresa pré-cadastrada por consultoria
// nasce UNCLAIMED, não "PRE_REGISTERED".
enum CompanyControlStatus {
  UNCLAIMED     // ninguém do lado da empresa ainda assumiu a conta (ex.: pré-cadastrada por consultoria/import, sem usuário próprio ainda)
  CLAIM_PENDING // um pedido de reivindicação foi aberto e aguarda aprovação (FUTURO — CompanyClaimRequest)
  CLAIMED       // controlada pelo próprio representante da empresa (default hoje — todo registro existente já está aqui)
  DISPUTED      // mais de uma reivindicação concorrente em aberto para a mesma empresa (FUTURO)
}

// Como a Company nasceu — independente de quem a controla hoje.
enum CompanyOrigin {
  SELF_REGISTRATION // criada via /register pela própria empresa (default hoje)
  SST_PROVIDER       // criada por uma consultoria SST no pré-cadastro (FUTURO)
  SUPER_ADMIN        // criada manualmente por um operador da plataforma (FUTURO)
  IMPORT             // criada por rotina de importação em lote (FUTURO)
}

// Tipo do documento em `documentOriginal`/`documentNormalized` (preparação
// para suportar cadastro estrangeiro no futuro; nesta migration nenhum dos
// dois campos é preenchido).
enum CompanyDocumentType {
  CNPJ
  FOREIGN_REGISTRATION
}

