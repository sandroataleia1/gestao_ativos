# Environment variables declared in this file are NOT automatically loaded by Prisma.
# prisma.config.ts loads them via `import "dotenv/config";`.

# Postgres local (docker compose up -d), porta mapeada em 5433 para não colidir
# com outro Postgres já em uso na 5432 nesta máquina.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/gestao_ativos?schema=public"

# Better Auth — gere um valor com:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=""
# `npm run dev`/`npm start` usam a porta 3010 (ver package.json) para não
# colidir com outros serviços na 3000 desta máquina.
BETTER_AUTH_URL="http://localhost:3010"

# Servidor Evolution API (WhatsApp) da plataforma — compartilhado por todas
# as empresas, cada uma com sua própria instância criada via
# app/(app)/configuracoes (ver lib/evolution-api.ts). Segredo de servidor,
# nunca por empresa; sem isso, "Conectar WhatsApp" fica indisponível.
EVOLUTION_API_URL=""
EVOLUTION_API_ADMIN_KEY=""

# Monitoramento de erros (lib/monitoring.ts, instrumentation.ts). Sem DSN,
# a aplicação funciona normalmente e só cai no fallback de log estruturado
# (console.error/warn) — nenhum outro arquivo precisa mudar quando um
# projeto Sentry for criado e o DSN for preenchido aqui.
SENTRY_DSN=""

# Envio de e-mail transacional (lib/mail.ts) — hoje usado só para
# recuperação de senha (lib/auth.ts `sendResetPassword`). Sem SMTP_HOST, a
# aplicação funciona normalmente e só loga um aviso em vez de enviar de
# verdade — útil para dev local sem servidor SMTP configurado.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Remetente exibido no e-mail; se vazio, usa SMTP_USER.
SMTP_FROM=""

# Observabilidade (docs/observability.md). LOG_LEVEL: nível do logger
# estruturado (lib/logger.ts) — "debug"|"info"|"warn"|"error", default "info".
LOG_LEVEL="info"
# METRICS_TOKEN: protege GET /api/metrics (Authorization: Bearer <token>).
# Opcional — sem ele, o endpoint fica aberto (recomenda-se restringir por
# rede/nginx em produção se não for configurado).
METRICS_TOKEN=""
