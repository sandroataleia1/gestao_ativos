# Template de variáveis para o deploy com Docker Compose (produção).
# Copie para `.env.production` (git-ignorado, nunca versionar o real):
#   cp .env.production.example .env.production
# E preencha os valores abaixo. Usado por:
#   docker compose -f docker-compose.prod.yml --env-file .env.production <comando>
# (todos os comandos documentados em docs/deployment.md já usam esse par
# de flags).
#
# Diferente do `.env`/`.env.example` da raiz (que são pro `npm run dev`/
# `npm start` direto no host, fora de container) — não confundir os dois.

NODE_ENV=production

# --- Postgres ---------------------------------------------------------
# Usados tanto pelo container `postgres` (cria o usuário/banco na primeira
# subida) quanto para montar o DATABASE_URL do `app` dentro do
# docker-compose.prod.yml (o app nunca lê estas 3 variáveis diretamente).
POSTGRES_USER=patrium
POSTGRES_PASSWORD=
POSTGRES_DB=gestao_ativos

# --- Domínio / TLS ------------------------------------------------------
# Usado em nginx/conf.d/patrium.conf (substituir __DOMAIN__ manualmente,
# ver docs/deployment.md) e por scripts/init-letsencrypt.sh.
DOMAIN=patrium.exemplo.com.br
CERTBOT_EMAIL=

# --- Better Auth --------------------------------------------------------
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=
# URL pública (com https://, mesmo domínio de DOMAIN acima).
BETTER_AUTH_URL=https://patrium.exemplo.com.br

# --- Evolution API (WhatsApp) --------------------------------------------
# Servidor compartilhado por todas as empresas (ver lib/evolution-api.ts) —
# sem isso, "Conectar WhatsApp" fica indisponível, mas o resto do app
# funciona normalmente.
EVOLUTION_API_URL=
EVOLUTION_API_ADMIN_KEY=

# --- Monitoramento de erros (lib/monitoring.ts) --------------------------
# Sem DSN, cai no fallback de log estruturado (console.error/warn).
SENTRY_DSN=

# --- E-mail transacional (lib/mail.ts) -----------------------------------
# Usado hoje só para recuperação de senha. Sem SMTP_HOST, só loga um aviso
# em vez de enviar de verdade.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Observabilidade (docs/observability.md) -----------------------------
LOG_LEVEL=info
# Protege GET /api/metrics (Authorization: Bearer <token>). Recomendado
# definir em produção — sem ele, o endpoint fica aberto (mitigue também
# restringindo por rede/nginx se preferir não usar token).
METRICS_TOKEN=
