# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Templates sem segredo nenhum — sempre versionados (ver .env.example,
# .env.production.example).
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Deploy de produção (docker-compose.prod.yml) — gerados/baixados em
# runtime na VPS, nunca versionados: certificados TLS (certbot/conf) e
# desafios ACME (certbot/www) do Let's Encrypt, dumps de backup do Postgres.
/certbot/
/backups/

# Dumps de backup do Postgres (pg_dump/psql) — nunca versionar, onde quer
# que sejam gerados (não só em /backups/, redundante de propósito: cobre
# qualquer dump gerado fora dessa pasta por engano, ex.: scratchpad, raiz do
# projeto). As duas exceções abaixo são intencionais e NÃO são dumps:
# migrations reais (prisma/migrations/**/migration.sql) sempre devem ser
# versionadas, e o SQL de propostas em revisão (prisma/proposed/**/*.sql)
# também é deliberadamente versionado para permitir review em PR.
*.sql
*.sql.gz
*.dump
!prisma/migrations/**/migration.sql
!prisma/proposed/**/*.sql

# Allowlist local de comandos aprovados no Claude Code — acumula strings de
# comandos já executados (podem conter segredos colados em bash inline, ex.:
# senha de VPS), nunca deve ir pro histórico do git.
.claude/settings.json
